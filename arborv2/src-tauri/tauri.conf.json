{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arbor V2",
  "version": "0.1.0",
  "identifier": "com.anandb71.arborv2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Arbor V2",
        "width": 1480,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
